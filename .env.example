# ============================================
# Focus AI Studio - Environment Variables
# ============================================

# 🎯 Gemini AI API (Fallback - Opcional)
# Se usa como fuente de respaldo cuando no hay eventos de APIs públicas
# Consigue tu API key en: https://ai.google.dev/
GEMINI_API_KEY="MI_GEMINI_API_KEY"

# 🔐 Firebase Authentication (Opcional - modo demo si no está configurado)
# Si no se configure, la app usa modo demo con usuarios de prueba
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""

# 🎟️ SeatGeek API (Recomendado - gratuita)
# Fuente principal de eventos reales: conciertos, deportes, teatro
# Registro gratuito: https://platform.seatgeek.com/
# After registration, create an app to get client_id
SEATGEEK_CLIENT_ID="TU_CLIENT_ID_AQUI"
# Opcional: Solo si necesitas endpoints privados
SEATGEEK_CLIENT_SECRET=""

# 🌐 Despliegue
# URL de la aplicación (auto-configurada en producción)
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Nota:
# - Para modo demo (sin APIs): solo necesitas GEMINI_API_KEY opcional
# - Para eventos reales: configura SEATGEEK_CLIENT_ID
# - Firebase es opcional (autenticación demo sin Firebase)
